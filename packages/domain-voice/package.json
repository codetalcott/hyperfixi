{
  "name": "@lokascript/domain-voice",
  "version": "2.5.1",
  "description": "Multilingual voice/accessibility commands — 14 commands in 8 languages for speech-controlled web interaction",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist --noEmit false",
    "test": "vitest",
    "test:run": "vitest run",
    "test:check": "VITEST_QUIET=1 bash ../../scripts/vitest-run.sh --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lokascript/framework": "^2.5.1"
  },
  "devDependencies": {
    "@lokascript/domain-toolkit": "^2.5.1",
    "@types/node": "^25.9.3",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/domain-voice"
  }
}
