    },
    "./browser/es": {
      "default": "./dist/hyperscript-i18n-es.global.js"
    },
    "./browser/fr": {
      "default": "./dist/hyperscript-i18n-fr.global.js"
    },
    "./browser/he": {
      "default": "./dist/hyperscript-i18n-he.global.js"
