{
  "name": "@lokascript/domain-jsx",
  "version": "2.7.2",
  "description": "Multilingual JSX DSL built on @lokascript/framework - proof of cross-domain generality",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist --noEmit false",
    "pretest": "../../scripts/ensure-fresh.sh ../framework ../semantic ../intent ../domain-toolkit",
    "test": "vitest",
    "test:run": "vitest run",
    "test:check": "VITEST_QUIET=1 bash ../../scripts/vitest-run.sh --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lokascript/framework": "^2.7.2",
    "@lokascript/semantic": "^2.7.2"
  },
  "devDependencies": {
    "@lokascript/domain-toolkit": "^2.7.2",
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "keywords": [
    "jsx",
    "react",
    "multilingual",
    "dsl",
    "i18n",
    "parser",
    "lokascript",
    "framework"
  ],
  "author": "LokaScript Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/domain-jsx"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
