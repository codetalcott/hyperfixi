{
  "name": "@hyperfixi/patterns-reference",
  "version": "2.7.2",
  "description": "Queryable patterns database for hyperscript with multilingual translations and LLM support",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js"
    },
    "./sync": {
      "types": "./dist/sync/index.d.ts",
      "import": "./dist/sync/index.mjs",
      "require": "./dist/sync/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "db:init": "tsx scripts/init-db.ts",
    "db:init:force": "tsx scripts/init-db.ts --force",
    "sync:translations": "tsx scripts/sync-translations.ts",
    "seed:llm": "tsx scripts/seed-llm-examples.ts",
    "populate": "npm run db:init:force && npm run sync:translations && npm run seed:llm && npm run db:fix-translations",
    "db:fix-translations": "tsx scripts/run-sql.ts scripts/fix-translations.sql",
    "populate:dry-run": "npm run db:init:force && tsx scripts/sync-translations.ts --dry-run && tsx scripts/seed-llm-examples.ts --dry-run",
    "validate": "tsx scripts/validate-all.ts",
    "validate:fix": "tsx scripts/validate-all.ts --fix",
    "verify": "tsx scripts/verify-translations.ts",
    "verify:verbose": "tsx scripts/verify-translations.ts --verbose",
    "test:check": "VITEST_QUIET=1 bash ../../scripts/vitest-run.sh --reporter=dot",
    "verify:engines": "tsx scripts/verify-engines.ts --update-db"
  },
  "keywords": [
    "hyperscript",
    "patterns",
    "multilingual",
    "i18n",
    "reference",
    "llm",
    "database"
  ],
  "author": "LokaScript Contributors",
  "license": "MIT",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/patterns-reference"
  },
  "bugs": {
    "url": "https://github.com/codetalcott/hyperfixi/issues"
  },
  "homepage": "https://github.com/codetalcott/hyperfixi/tree/main/packages/patterns-reference#readme",
  "dependencies": {
    "@lokascript/semantic": "^2.7.2",
    "better-sqlite3": "^13.0.1"
  },
  "devDependencies": {
    "@hyperfixi/core": "^2.7.2",
    "@hyperfixi/reactivity": "^2.7.2",
    "@hyperfixi/realtime": "^2.7.2",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^26.1.1",
    "hyperscript.org": "0.9.93",
    "jsdom": "^29.1.1",
    "tsup": "^8.0.0",
    "tsx": "^4.23.1",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "data",
    "src",
    "!src/**/*.test.ts",
    "!src/**/*.spec.ts"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  }
}
