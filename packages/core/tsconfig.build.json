{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "composite": false,
    "incremental": false
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/legacy/**/*",
    "src/context/**/*",
    "src/performance/benchmarks.ts",
    "src/test-helpers/**/*",
    "vitest.config.ts",
    "src/compatibility/browser-bundle-hybrid-hx-v4.ts"
  ]
}
