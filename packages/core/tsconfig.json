{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],

    // Output configuration
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "outDir": "./dist",
    "removeComments": true,

    // Type checking
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "exactOptionalPropertyTypes": false,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,

    // Module resolution
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Path mapping for clean imports. `paths` is resolved relative to this
    // tsconfig (baseUrl was dropped — deprecated in TS 6.0, removed in TS 7.0),
    // so each mapping is prefixed with ./src to preserve the previous resolution.
    "paths": {
      "@/*": ["./src/*"],
      "@test/*": ["./src/test/*"],
      "@core/*": ["./src/core/*"],
      "@commands/*": ["./src/commands/*"],
      "@expressions/*": ["./src/expressions/*"],
      "@features/*": ["./src/features/*"],
      "@types/*": ["./src/types/*"]
    },

    // Advanced options
    "incremental": true,
    "composite": true
  },

  "include": ["src/**/*", "vitest.config.ts"],

  "exclude": [
    "node_modules",
    "dist",
    "src/legacy/**/*",
    "src/context/**/*",
    "src/performance/benchmarks.ts",
    "src/test-helpers/**/*"
  ],

  "ts-node": {
    "esm": true
  }
}
