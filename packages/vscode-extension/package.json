{
  "name": "lokascript-vscode",
  "displayName": "Hyperscript Language Support",
  "description": "Language support for _hyperscript and LokaScript — syntax highlighting, completions, hover docs, diagnostics, 21 language i18n, and interactive debugging",
  "version": "2.2.0",
  "publisher": "lokascript",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Linters",
    "Snippets",
    "Debuggers"
  ],
  "keywords": [
    "hyperscript",
    "_hyperscript",
    "lokascript",
    "htmx",
    "html",
    "multilingual",
    "debugger"
  ],
  "activationEvents": [
    "onLanguage:html",
    "onDebugResolve:hyperfixi"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "languages": [
      {
        "id": "hyperscript",
        "aliases": [
          "Hyperscript",
          "LokaScript"
        ],
        "extensions": [
          ".hs"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "hyperscript",
        "scopeName": "source.hyperscript",
        "path": "./syntaxes/hyperscript.tmLanguage.json"
      },
      {
        "scopeName": "inline.hyperscript",
        "path": "./syntaxes/hyperscript-injection.tmLanguage.json",
        "injectTo": [
          "text.html.basic",
          "text.html.derivative",
          "text.html.vue",
          "source.vue",
          "source.svelte"
        ],
        "embeddedLanguages": {
          "meta.embedded.inline.hyperscript": "hyperscript"
        }
      }
    ],
    "commands": [
      {
        "command": "lokascript.restartServer",
        "title": "LokaScript: Restart Language Server"
      },
      {
        "command": "lokascript.debug.connect",
        "title": "HyperFixi: Connect Debugger",
        "icon": "$(debug-start)"
      },
      {
        "command": "lokascript.debug.disconnect",
        "title": "HyperFixi: Disconnect Debugger",
        "icon": "$(debug-stop)"
      },
      {
        "command": "lokascript.debug.continue",
        "title": "HyperFixi: Continue",
        "icon": "$(debug-continue)"
      },
      {
        "command": "lokascript.debug.pause",
        "title": "HyperFixi: Pause",
        "icon": "$(debug-pause)"
      },
      {
        "command": "lokascript.debug.stepOver",
        "title": "HyperFixi: Step Over",
        "icon": "$(debug-step-over)"
      },
      {
        "command": "lokascript.debug.stepInto",
        "title": "HyperFixi: Step Into",
        "icon": "$(debug-step-into)"
      },
      {
        "command": "lokascript.debug.stepOut",
        "title": "HyperFixi: Step Out",
        "icon": "$(debug-step-out)"
      },
      {
        "command": "lokascript.inventory",
        "title": "HyperFixi: Open Template Inventory",
        "icon": "$(list-tree)"
      },
      {
        "command": "lokascript.inventory.stop",
        "title": "HyperFixi: Stop Template Inventory",
        "icon": "$(stop)"
      }
    ],
    "configuration": {
      "type": "object",
      "title": "Hyperscript",
      "properties": {
        "lokascript.language": {
          "type": "string",
          "default": "en",
          "description": "Primary language for keyword suggestions (en, es, ja, ko, zh, de, fr, pt, ar, etc.)"
        },
        "lokascript.maxDiagnostics": {
          "type": "number",
          "default": 100,
          "description": "Maximum number of diagnostics to show per file"
        },
        "lokascript.trace.server": {
          "type": "string",
          "enum": [
            "off",
            "messages",
            "verbose"
          ],
          "default": "off",
          "description": "Traces the communication between VS Code and the language server"
        },
        "lokascript.debug.url": {
          "type": "string",
          "default": "ws://localhost:9229",
          "description": "WebSocket URL for the HyperFixi debug server"
        },
        "lokascript.debug.autoConnect": {
          "type": "boolean",
          "default": false,
          "description": "Automatically connect to debug server on extension activation"
        },
        "lokascript.debug.verbose": {
          "type": "boolean",
          "default": false,
          "description": "Log all execution snapshots to the output channel (verbose mode)"
        },
        "lokascript.inventory.port": {
          "type": "number",
          "default": 4200,
          "description": "Port for the Template Inventory server"
        }
      }
    },
    "debuggers": [
      {
        "type": "hyperfixi",
        "label": "HyperFixi",
        "languages": [
          "html",
          "hyperscript"
        ],
        "configurationAttributes": {
          "launch": {
            "properties": {
              "url": {
                "type": "string",
                "description": "URL of the page with hyperscript",
                "default": "http://localhost:3000"
              },
              "webSocketUrl": {
                "type": "string",
                "description": "WebSocket URL for the debug server",
                "default": "ws://localhost:9229"
              }
            }
          },
          "attach": {
            "properties": {
              "webSocketUrl": {
                "type": "string",
                "description": "WebSocket URL for the debug server",
                "default": "ws://localhost:9229"
              }
            }
          }
        },
        "configurationSnippets": [
          {
            "label": "HyperFixi: Debug Page",
            "description": "Launch a debug session connected to a HyperFixi debug server",
            "body": {
              "type": "hyperfixi",
              "request": "launch",
              "name": "Debug HyperFixi",
              "url": "http://localhost:3000",
              "webSocketUrl": "ws://localhost:9229"
            }
          },
          {
            "label": "HyperFixi: Attach",
            "description": "Attach to a running HyperFixi debug session",
            "body": {
              "type": "hyperfixi",
              "request": "attach",
              "name": "Attach to HyperFixi",
              "webSocketUrl": "ws://localhost:9229"
            }
          }
        ]
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run generate:grammar && npm run compile && npm run bundle:server",
    "compile": "esbuild src/extension.ts --bundle --format=cjs --outfile=dist/extension.js --platform=node --external:vscode",
    "watch": "esbuild src/extension.ts --bundle --format=cjs --outfile=dist/extension.js --platform=node --external:vscode --watch",
    "typecheck": "tsc --noEmit",
    "generate:grammar": "npx tsx scripts/generate-grammar.ts",
    "bundle:server": "esbuild ../language-server/src/server.ts --bundle --format=esm --outfile=dist/server.mjs --platform=node --external:@hyperfixi/core --alias:@lokascript/semantic=../../packages/semantic/src/index.ts --alias:@hyperfixi/core/lsp-metadata=../../packages/core/src/lsp-metadata.ts --banner:js=\"import {createRequire} from 'module';const require=createRequire(import.meta.url);\"",
    "package": "vsce package --no-dependencies",
    "publish": "vsce publish --no-dependencies"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1",
    "ws": "^8.0.0"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "@vscode/vsce": "^2.0.0",
    "@lokascript/semantic": "*",
    "tsx": "^4.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/vscode-extension"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/codetalcott/hyperfixi/issues"
  },
  "homepage": "https://github.com/codetalcott/hyperfixi/tree/main/packages/vscode-extension#readme"
}
