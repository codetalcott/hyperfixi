{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Hyperscript Injection",
  "scopeName": "inline.hyperscript",
  "injectionSelector": "L:text.html -comment",
  "patterns": [
    {
      "include": "#hyperscript-attribute"
    },
    {
      "include": "#hyperscript-attribute-single"
    },
    {
      "include": "#hyperscript-script-tag"
    },
    {
      "include": "#template-component-body"
    },
    {
      "include": "#script-template-body"
    }
  ],
  "repository": {
    "hyperscript-attribute": {
      "begin": "(_)(=)(\")",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.hyperscript" },
        "2": { "name": "punctuation.separator.key-value.html" },
        "3": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "\"",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.html" }
      },
      "name": "meta.attribute.hyperscript.html",
      "contentName": "meta.embedded.inline.hyperscript",
      "patterns": [{ "include": "source.hyperscript" }]
    },
    "hyperscript-attribute-single": {
      "begin": "(_)(=)(')",
      "beginCaptures": {
        "1": { "name": "entity.other.attribute-name.hyperscript" },
        "2": { "name": "punctuation.separator.key-value.html" },
        "3": { "name": "punctuation.definition.string.begin.html" }
      },
      "end": "'",
      "endCaptures": {
        "0": { "name": "punctuation.definition.string.end.html" }
      },
      "name": "meta.attribute.hyperscript.html",
      "contentName": "meta.embedded.inline.hyperscript",
      "patterns": [{ "include": "source.hyperscript" }]
    },
    "hyperscript-script-tag": {
      "begin": "(<)(script)(\\s+)(type)(=)(\"text/hyperscript\"|'text/hyperscript')([^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "text.html" },
        "4": { "name": "entity.other.attribute-name.html" },
        "5": { "name": "punctuation.separator.key-value.html" },
        "6": { "name": "string.quoted.html" },
        "7": { "name": "text.html" },
        "8": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.hyperscript",
      "contentName": "meta.embedded.inline.hyperscript",
      "patterns": [{ "include": "source.hyperscript" }]
    },
    "template-component-body": {
      "comment": "v2 component template body — line-oriented #if/#for directives + ${...} interpolation. We don't include the full hyperscript scope since the body is HTML; just inject directive recognition and interpolation expressions.",
      "begin": "(?i)(<)(template)(\\s+[^>]*\\bcomponent=(\"[^\"]+\"|'[^']+')[^>]*)(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.html" },
        "3": { "patterns": [{ "include": "text.html.basic#tag-stuff" }] },
        "5": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(template)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.template.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.template-component.hyperscript",
      "patterns": [
        { "include": "#template-directives" },
        { "include": "#template-interpolation" },
        { "include": "text.html.basic" }
      ]
    },
    "script-template-body": {
      "comment": "Upstream form: <script type=\"text/hyperscript-template\" component=\"...\">. Same body shape as template-component-body.",
      "begin": "(<)(script)\\s+[^>]*\\btype=(\"text/hyperscript-template\"|'text/hyperscript-template')[^>]*\\bcomponent=(\"[^\"]+\"|'[^']+')[^>]*(>)",
      "beginCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "string.quoted.html" },
        "4": { "name": "string.quoted.html" },
        "5": { "name": "punctuation.definition.tag.end.html" }
      },
      "end": "(</)(script)(>)",
      "endCaptures": {
        "1": { "name": "punctuation.definition.tag.begin.html" },
        "2": { "name": "entity.name.tag.script.html" },
        "3": { "name": "punctuation.definition.tag.end.html" }
      },
      "name": "meta.embedded.block.template-component.hyperscript",
      "patterns": [
        { "include": "#template-directives" },
        { "include": "#template-interpolation" },
        { "include": "text.html.basic" }
      ]
    },
    "template-directives": {
      "patterns": [
        {
          "name": "keyword.control.directive.if.hyperscript",
          "match": "^\\s*#if\\b.*$"
        },
        {
          "name": "keyword.control.directive.for.hyperscript",
          "match": "^\\s*#for\\b.*$"
        },
        {
          "name": "keyword.control.directive.else.hyperscript",
          "match": "^\\s*#else\\s*$"
        },
        {
          "name": "keyword.control.directive.end.hyperscript",
          "match": "^\\s*#end\\s*$"
        },
        {
          "name": "keyword.control.directive.continue.hyperscript",
          "match": "^\\s*#continue\\s*$"
        }
      ]
    },
    "template-interpolation": {
      "comment": "${...} interpolation inside template bodies. The expression scope is hyperscript so ^var, attrs.X, etc. highlight correctly.",
      "begin": "\\$\\{",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.template-expression.begin.hyperscript" }
      },
      "end": "\\}",
      "endCaptures": {
        "0": { "name": "punctuation.definition.template-expression.end.hyperscript" }
      },
      "name": "meta.template.expression.hyperscript",
      "contentName": "meta.embedded.inline.hyperscript",
      "patterns": [{ "include": "source.hyperscript" }]
    }
  }
}
