{
  "name": "@hyperfixi/mcp-server",
  "version": "2.7.2",
  "description": "Model Context Protocol server for HyperFixi hyperscript development",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "hyperfixi-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "prebuild": "../../scripts/ensure-fresh.sh ../compilation-service ../semantic ../framework ../intent ../domain-config ../domain-learn ../planner",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "pretest": "../../scripts/ensure-fresh.sh ../compilation-service ../semantic ../framework ../intent ../domain-config ../domain-learn ../planner",
    "test": "vitest",
    "typecheck": "tsc --noEmit",
    "service:setup": "echo 'Copy com.lokascript.mcp-server.plist.example to com.lokascript.mcp-server.plist and update paths, then run service:install'",
    "service:install": "test -f com.lokascript.mcp-server.plist && cp com.lokascript.mcp-server.plist ~/Library/LaunchAgents/ && launchctl load ~/Library/LaunchAgents/com.lokascript.mcp-server.plist || echo 'ERROR: First copy .plist.example to .plist and configure paths'",
    "service:uninstall": "launchctl unload ~/Library/LaunchAgents/com.lokascript.mcp-server.plist && rm ~/Library/LaunchAgents/com.lokascript.mcp-server.plist",
    "service:start": "launchctl start com.lokascript.mcp-server",
    "service:stop": "launchctl stop com.lokascript.mcp-server",
    "service:restart": "launchctl stop com.lokascript.mcp-server && launchctl start com.lokascript.mcp-server",
    "service:status": "launchctl list | grep lokascript || echo 'Not running'",
    "service:logs": "tail -f logs/stdout.log logs/stderr.log",
    "test:check": "VITEST_QUIET=1 bash ../../scripts/vitest-run.sh --reporter=dot"
  },
  "keywords": [
    "mcp",
    "hyperscript",
    "hyperfixi",
    "ai",
    "llm",
    "development-tools"
  ],
  "author": "LokaScript Contributors",
  "license": "MIT",
  "dependencies": {
    "@hyperfixi/patterns-reference": "^2.7.2",
    "@lokascript/compilation-service": "^2.7.2",
    "@lokascript/domain-config": "^2.7.2",
    "@lokascript/framework": "^2.7.2",
    "@lokascript/planner": "^2.7.2",
    "@lokascript/semantic": "^2.7.2",
    "@modelcontextprotocol/sdk": "^1.25.0",
    "yaml": "^2.8.3"
  },
  "peerDependencies": {
    "@hyperfixi/core": "^2.7.2",
    "@hyperfixi/patterns-reference": "^2.7.2",
    "@hyperfixi/server-bridge": "^2.7.2",
    "@lokascript/compilation-service": "^2.7.2",
    "@lokascript/domain-bdd": "^2.7.2",
    "@lokascript/domain-behaviorspec": "^2.7.2",
    "@lokascript/domain-flow": "^2.7.2",
    "@lokascript/domain-jsx": "^2.7.2",
    "@lokascript/domain-learn": "^2.7.2",
    "@lokascript/domain-llm": "^2.7.2",
    "@lokascript/domain-sql": "^2.7.2",
    "@lokascript/domain-todo": "^2.7.2",
    "@lokascript/domain-voice": "^2.7.2",
    "@lokascript/framework": "^2.7.2",
    "@lokascript/semantic": "^2.7.2"
  },
  "peerDependenciesMeta": {
    "@lokascript/compilation-service": {
      "optional": true
    },
    "@lokascript/framework": {
      "optional": true
    },
    "@hyperfixi/core": {
      "optional": true
    },
    "@hyperfixi/patterns-reference": {
      "optional": true
    },
    "@lokascript/semantic": {
      "optional": true
    },
    "@lokascript/domain-sql": {
      "optional": true
    },
    "@lokascript/domain-bdd": {
      "optional": true
    },
    "@lokascript/domain-behaviorspec": {
      "optional": true
    },
    "@lokascript/domain-jsx": {
      "optional": true
    },
    "@lokascript/domain-learn": {
      "optional": true
    },
    "@lokascript/domain-flow": {
      "optional": true
    },
    "@lokascript/domain-llm": {
      "optional": true
    },
    "@lokascript/domain-todo": {
      "optional": true
    },
    "@lokascript/domain-voice": {
      "optional": true
    },
    "@hyperfixi/server-bridge": {
      "optional": true
    }
  },
  "devDependencies": {
