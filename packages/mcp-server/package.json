    "@lokascript/domain-bdd": "^2.7.2",
    "@lokascript/domain-behaviorspec": "^2.7.2",
    "@lokascript/domain-flow": "^2.7.2",
    "@lokascript/domain-jsx": "^2.7.2",
    "@lokascript/domain-learn": "^2.7.2",
    "@lokascript/domain-llm": "^2.7.2",
    "@lokascript/domain-sql": "^2.7.2",
    "@lokascript/domain-todo": "^2.7.2",
