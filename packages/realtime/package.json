{
  "name": "@hyperfixi/realtime",
  "version": "2.7.2",
  "description": "Realtime features for hyperfixi — adds `socket`, `eventsource`, and `worker` top-level features (upstream _hyperscript 0.9.93 extensions; worker is an async main-thread shim).",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest",
    "test:run": "vitest run",
    "test:check": "VITEST_QUIET=1 bash ../../scripts/vitest-run.sh --reporter=dot",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hyperfixi/core": "^2.7.2"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "happy-dom": "^20.10.6",
    "tsup": "^8.0.0",
    "typescript": "^7.0.2",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "src",
    "LICENSE"
  ],
  "keywords": [
    "hyperfixi",
    "hyperscript",
    "websocket",
    "sse",
    "eventsource",
    "worker",
    "realtime",
    "plugin",
    "_hyperscript"
  ],
  "author": "LokaScript Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/realtime"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "publishConfig": {
    "access": "public"
  }
}
