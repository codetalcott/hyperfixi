{
  "name": "@hyperscript-tools/i18n",
  "version": "2.3.1",
  "description": "Build-time translation for hyperscript code samples — generate per-language HTML from a canonical English source",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "hyperscript-i18n": "dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./eleventy": {
      "types": "./dist/eleventy.d.ts",
      "import": "./dist/eleventy.js"
    },
    "./cli": {
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/eleventy.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts src/eleventy.ts --format esm --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test test/*.test.mjs"
  },
  "keywords": [
    "hyperscript",
    "_hyperscript",
    "i18n",
    "internationalization",
    "translation",
    "build-time",
    "eleventy",
    "11ty",
    "cli",
    "static-site"
  ],
  "author": "HyperFixi Contributors",
  "license": "MIT",
  "dependencies": {
    "@lokascript/i18n": "*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/hyperscript-tools-i18n"
  },
  "bugs": {
    "url": "https://github.com/codetalcott/hyperfixi/issues"
  },
  "homepage": "https://github.com/codetalcott/hyperfixi/tree/main/packages/hyperscript-tools-i18n#readme",
  "engines": {
    "node": ">=18.0.0"
  }
}
