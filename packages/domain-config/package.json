{
  "name": "@lokascript/domain-config",
  "version": "2.5.1",
  "description": "Shared domain-registry wiring + priority order for MCP servers and other consumers. Single source of truth for which LokaScript domains exist and how the dispatcher breaks ambiguity.",
  "type": "module",
  "sideEffects": false,
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup && npm run build:types",
    "build:types": "tsc --emitDeclarationOnly --outDir dist --noEmit false",
    "test": "vitest",
    "test:run": "vitest run",
    "test:check": "vitest run --reporter=dot 2>&1 | tail -5",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@lokascript/domain-bdd": "^2.5.1",
    "@lokascript/domain-behaviorspec": "^2.5.1",
    "@lokascript/domain-flow": "^2.5.1",
    "@lokascript/domain-jsx": "^2.5.1",
    "@lokascript/domain-llm": "^2.5.1",
    "@lokascript/domain-sql": "^2.5.1",
    "@lokascript/domain-todo": "^2.5.1",
    "@lokascript/domain-voice": "^2.5.1",
    "@lokascript/framework": "^2.5.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/codetalcott/hyperfixi.git",
    "directory": "packages/domain-config"
  },
  "publishConfig": {
    "access": "public"
  }
}
