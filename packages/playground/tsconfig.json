{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@hyperfixi/core/*": ["../core/src/*"],
      "@lokascript/semantic": ["../semantic/src"]
    }
  },
  "include": ["src/**/*.ts"]
}
