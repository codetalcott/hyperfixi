[
  {
    "id": "sel-001",
    "description": "ID selector (#)",
    "input": "[add patient:.active destination:#output]",
    "expected": {
      "kind": "command",
      "action": "add",
      "roles": {
        "patient": { "type": "selector", "value": ".active" },
        "destination": { "type": "selector", "value": "#output" }
      }
    }
  },
  {
    "id": "sel-002",
    "description": "Class selector (.)",
    "input": "[toggle patient:.highlight]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".highlight" }
      }
    }
  },
  {
    "id": "sel-003",
    "description": "Attribute selector ([])",
    "input": "[add patient:[data-active] destination:#output]",
    "expected": {
      "kind": "command",
      "action": "add",
      "roles": {
        "patient": { "type": "selector", "value": "[data-active]" },
        "destination": { "type": "selector", "value": "#output" }
      }
    }
  },
  {
    "id": "sel-004",
    "description": "ARIA selector (@)",
    "input": "[set destination:@role patient:button]",
    "expected": {
      "kind": "command",
      "action": "set",
      "roles": {
        "destination": { "type": "selector", "value": "@role" },
        "patient": { "type": "literal", "value": "button", "dataType": "string" }
      }
    }
  },
  {
    "id": "sel-005",
    "description": "Wildcard selector (*)",
    "input": "[remove patient:*hidden]",
    "expected": {
      "kind": "command",
      "action": "remove",
      "roles": {
        "patient": { "type": "selector", "value": "*hidden" }
      }
    }
  },
  {
    "id": "sel-006",
    "description": "Multiple selector types together",
    "input": "[add patient:.active destination:#container]",
    "expected": {
      "kind": "command",
      "action": "add",
      "roles": {
        "patient": { "type": "selector", "value": ".active" },
        "destination": { "type": "selector", "value": "#container" }
      }
    }
  },
  {
    "id": "sel-007",
    "description": "Selector literal with a child combinator (v2.0)",
    "input": "[toggle patient:<ul > li/>]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": "ul > li", "selectorKind": "complex" }
      }
    }
  },
  {
    "id": "sel-008",
    "description": "Selector literal carrying an attribute selector",
    "input": "[add patient:<[data-active]/> destination:#output]",
    "expected": {
      "kind": "command",
      "action": "add",
      "roles": {
        "patient": { "type": "selector", "value": "[data-active]", "selectorKind": "attribute" },
        "destination": { "type": "selector", "value": "#output", "selectorKind": "id" }
      }
    }
  },
  {
    "id": "sel-009",
    "description": "Selector literal forces a bare tag name to be a selector",
    "input": "[remove patient:<div/>]",
    "expected": {
      "kind": "command",
      "action": "remove",
      "roles": {
        "patient": { "type": "selector", "value": "div" }
      }
    }
  },
  {
    "id": "sel-010",
    "description": "Selector literal with a comma-separated group",
    "input": "[toggle patient:<.a, .b/>]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".a, .b", "selectorKind": "complex" }
      }
    }
  },
  {
    "id": "sel-011",
    "description": "Interior > does not close the literal; only the trailing /> does",
    "input": "[toggle patient:<div:has(> .child)/> destination:#out]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": "div:has(> .child)", "selectorKind": "complex" },
        "destination": { "type": "selector", "value": "#out", "selectorKind": "id" }
      }
    }
  },
  {
    "id": "sel-012",
    "description": "A /> inside a quoted attribute value does not close the literal",
    "input": "[toggle patient:<[data-x=\"a/>b\"]/>]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": "[data-x=\"a/>b\"]", "selectorKind": "attribute" }
      }
    }
  },
  {
    "id": "sel-013",
    "description": "Combinator wins over leading-character kind inference",
    "input": "[toggle patient:<.a > .b/>]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".a > .b", "selectorKind": "complex" }
      }
    }
  }
]
