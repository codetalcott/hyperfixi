[
  {
    "id": "basic-001",
    "description": "Toggle with class selector",
    "input": "[toggle patient:.active]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".active" }
      }
    }
  },
  {
    "id": "basic-002",
    "description": "Command with two selector roles",
    "input": "[toggle patient:.active destination:#button]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".active" },
        "destination": { "type": "selector", "value": "#button" }
      }
    }
  },
  {
    "id": "basic-003",
    "description": "Add command with selector roles",
    "input": "[add patient:.highlight destination:#output]",
    "expected": {
      "kind": "command",
      "action": "add",
      "roles": {
        "patient": { "type": "selector", "value": ".highlight" },
        "destination": { "type": "selector", "value": "#output" }
      }
    }
  },
  {
    "id": "basic-004",
    "description": "Custom domain roles (no schema)",
    "input": "[deploy destination:production source:main manner:rolling]",
    "expected": {
      "kind": "command",
      "action": "deploy",
      "roles": {
        "destination": { "type": "literal", "value": "production", "dataType": "string" },
        "source": { "type": "literal", "value": "main", "dataType": "string" },
        "manner": { "type": "literal", "value": "rolling", "dataType": "string" }
      }
    }
  },
  {
    "id": "basic-005",
    "description": "Fetch with URL and format",
    "input": "[fetch source:/api/users responseType:json]",
    "expected": {
      "kind": "command",
      "action": "fetch",
      "roles": {
        "source": { "type": "literal", "value": "/api/users", "dataType": "string" },
        "responseType": { "type": "literal", "value": "json", "dataType": "string" }
      }
    }
  },
  {
    "id": "basic-006",
    "description": "Command name is lowercased",
    "input": "[Toggle patient:.active]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": ".active" }
      }
    }
  },
  {
    "id": "basic-007",
    "description": "Role named __proto__ is an ordinary role, not a prototype write",
    "input": "[toggle __proto__:.active]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "__proto__": { "type": "selector", "value": ".active" }
      }
    }
  },
  {
    "id": "basic-008",
    "description": "Flag named __proto__ is an ordinary flag role",
    "input": "[column +__proto__]",
    "expected": {
      "kind": "command",
      "action": "column",
      "roles": {
        "__proto__": { "type": "flag", "name": "__proto__", "enabled": true }
      }
    }
  },
  {
    "id": "basic-009",
    "description": "Role named constructor is an ordinary role",
    "input": "[toggle constructor:.active]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "constructor": { "type": "selector", "value": ".active" }
      }
    }
  }
]
