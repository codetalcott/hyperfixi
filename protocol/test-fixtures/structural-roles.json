[
  {
    "id": "structural-001",
    "description": "Attribute selector in a structural role requires selector-literal delimiters (v2.0)",
    "input": "[if condition:<[data-active]/>]",
    "expected": {
      "kind": "command",
      "action": "if",
      "roles": {
        "condition": { "type": "selector", "value": "[data-active]", "selectorKind": "attribute" }
      }
    }
  },
  {
    "id": "structural-002",
    "description": "Nested command in structural role is parsed recursively",
    "input": "[if condition:\"x > 0\" then:[toggle patient:.active]]",
    "expected": {
      "kind": "command",
      "action": "if",
      "roles": {
        "condition": { "type": "literal", "value": "x > 0", "dataType": "string" }
      },
      "thenBranch": [
        {
          "kind": "command",
          "action": "toggle",
          "roles": {
            "patient": { "type": "selector", "value": ".active" }
          }
        }
      ]
    }
  },
  {
    "id": "structural-003",
    "description": "Zero-argument command in a structural role is preserved (v1.x silently dropped it)",
    "input": "[on event:click body:[halt]]",
    "expected": {
      "kind": "event-handler",
      "action": "on",
      "roles": {
        "event": { "type": "literal", "value": "click", "dataType": "string" }
      },
      "body": [
        {
          "kind": "command",
          "action": "halt",
          "roles": {}
        }
      ]
    }
  },
  {
    "id": "structural-004",
    "description": "A structural [...] value is always a command; an attr selector with a space is a selector literal",
    "input": "[if condition:<[aria-label=\"Close menu\"]/> then:[exit]]",
    "expected": {
      "kind": "command",
      "action": "if",
      "roles": {
        "condition": {
          "type": "selector",
          "value": "[aria-label=\"Close menu\"]",
          "selectorKind": "attribute"
        }
      },
      "thenBranch": [
        {
          "kind": "command",
          "action": "exit",
          "roles": {}
        }
      ]
    }
  },
  {
    "id": "structural-005",
    "description": "A bare attribute selector is still a selector in a NON-structural role",
    "input": "[toggle patient:[data-active]]",
    "expected": {
      "kind": "command",
      "action": "toggle",
      "roles": {
        "patient": { "type": "selector", "value": "[data-active]", "selectorKind": "attribute" }
      }
    }
  }
]
