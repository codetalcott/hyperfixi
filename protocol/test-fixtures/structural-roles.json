[
  {
    "id": "structural-001",
    "description": "Attribute selector in structural role (no space or colon inside brackets) stays as selector value",
    "input": "[if condition:[data-active]]",
    "expected": {
      "kind": "command",
      "action": "if",
      "roles": {
        "condition": { "type": "selector", "value": "[data-active]" }
      }
    }
  },
  {
    "id": "structural-002",
    "description": "Nested command in structural role (has space and colon inside brackets) is parsed recursively",
    "input": "[if condition:\"x > 0\" then:[toggle patient:.active]]",
    "expected": {
      "kind": "command",
      "action": "if",
      "roles": {
        "condition": { "type": "literal", "value": "x > 0", "dataType": "string" }
      },
      "thenBranch": [
        {
          "kind": "command",
          "action": "toggle",
          "roles": {
            "patient": { "type": "selector", "value": ".active" }
          }
        }
      ]
    }
  }
]
