        {
          "kind": "command",
          "action": "toggle",
          "roles": {
            "patient": { "type": "selector", "value": ".active" }
          }
        }
      ],
      "elseBranch": [
        {
          "kind": "command",
          "action": "remove",
          "roles": {
            "patient": { "type": "selector", "value": ".active" }
          }
        }
      ]
    }
  },
  {
    "id": "conditional-003",
